{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings */
    "module": "node16",
    "target": "ES2020",
    "moduleResolution": "node16",
    "lib": ["ESNext"],

    /* Other Outputs */
    "sourceMap": true,
    "declaration": false, // Usually not needed for app development, keeps dist clean

    /* Stricter Typechecking Options */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitAny": true,

    /* Recommended Options */
    "esModuleInterop": true,         // Critical for importing bcrypt and express
    "skipLibCheck": true,            // Ignores type errors in node_modules
    "verbatimModuleSyntax": false,   // MUST be false for CommonJS exports to work
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}